# ── GCP Project ───────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── GCS Bucket ────────────────────────────────────────────────────
GCS_BUCKET=your-bucket-name

# ── Service Account Key ───────────────────────────────────────────
# Path to your downloaded GCP service account JSON key
# Never commit the actual key file — it lives in keys/ which is gitignored
GOOGLE_APPLICATION_CREDENTIALS=keys/service-account.json

# ── BigQuery ──────────────────────────────────────────────────────
BQ_DATASET=raw
BQ_TABLE=github_events

# ── Ingestion Date Override ───────────────────────────────────────
# Used by github_ingest.py and gcs_to_bigquery.py
# Format: YYYY-MM-DD
# If not set, defaults to yesterday automatically
INGEST_DATE=2025-12-01

# ── Bruin ─────────────────────────────────────────────────────────
# BRUIN_START_DATE is injected automatically by Bruin at runtime
# based on the --start-date flag passed to bruin run
# You do not need to set this manually

# ── Kestra ────────────────────────────────────────────────────────
# Base64 encoded service account key for Kestra KV Store
# Generate with: echo "$GCP_SA_KEY" | base64 -w 0
# Store the output in Kestra UI → Namespace → KV Store → GCP_SA_KEY_B64
GCP_SA_KEY_B64=your-base64-encoded-service-account-json 
